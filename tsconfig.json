{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "moduleResolution": "node",
        "strict": false,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./",
        "rootDir": "./",
        "allowJs": true,
        "esModuleInterop": true,
        "noImplicitAny": false
    },
    "include": ["*.ts", "**/*.ts"],
    "exclude": ["node_modules"]
}